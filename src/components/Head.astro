---
/**
 * Custom Head Component für CodeBack Wissen
 * Erweitert den Standard-Head um Schema.org JSON-LD
 */
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Head.astro';
import SchemaOrg from './SchemaOrg.astro';

// Alle Props durchreichen
const props = Astro.props;

// Extrahiere was wir brauchen - defensiv
const title = props?.entry?.data?.title || 'CodeBack Wissen';
const description = props?.entry?.data?.description;
const slug = props?.entry?.id?.replace(/\/index$/, '').replace(/\.mdx?$/, '') || '';
---

<Default {...props} />
<SchemaOrg 
  title={title} 
  description={description} 
  slug={slug}
/>
<!-- Umami Analytics -->
<script defer src="https://stats.stevennoack.de/script.js" data-website-id="2948a6ed-1f76-4bfc-8849-fb34b7f478be"></script>
