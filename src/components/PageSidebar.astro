---
/**
 * Custom PageSidebar mit Download-Button
 * Zeigt einen Download-Link für die MD-Version des Artikels
 */
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/PageSidebar.astro';

// Aktuelle Seite ermitteln aus der URL
const pathname = Astro.url.pathname;
// /referenz/llm-optimierung/ → referenz/llm-optimierung
const slug = pathname.replace(/^\//, '').replace(/\/$/, '');

// Download-URL erstellen
const downloadUrl = `/downloads/${slug}.md`;
const hasDownload = slug && slug !== '' && slug !== 'index';
---

<Default {...Astro.props}><slot /></Default>

{hasDownload && (
  <div class="md-download">
    <a href={downloadUrl} download class="md-download-link">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
        <polyline points="7 10 12 15 17 10"/>
        <line x1="12" y1="15" x2="12" y2="3"/>
      </svg>
      <span>Als Markdown herunterladen</span>
    </a>
    <p class="md-download-hint">
      Für Nostr, Obsidian oder andere Tools
    </p>
  </div>
)}

<style>
  .md-download {
    margin-top: 1.5rem;
    padding-top: 1rem;
    border-top: 1px solid var(--sl-color-gray-5);
  }
  
  .md-download-link {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.8rem;
    color: var(--sl-color-text);
    background: var(--sl-color-gray-6);
    border-radius: 0.375rem;
    text-decoration: none;
    transition: background-color 0.15s, color 0.15s;
  }
  
  .md-download-link:hover {
    background: var(--sl-color-gray-5);
    color: var(--sl-color-text-accent);
  }
  
  .md-download-link svg {
    flex-shrink: 0;
  }
  
  .md-download-hint {
    margin-top: 0.5rem;
    font-size: 0.7rem;
    color: var(--sl-color-gray-3);
  }
</style>
