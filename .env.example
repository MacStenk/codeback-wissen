# CodeBack Wissen - Environment Variables
# Copy to .env and fill in your values

# ===========================================
# SIGNING (VisionFusen Bunker)
# ===========================================

# Bunker API URL
BUNKER_URL=https://bunker.visionfusen.org

# API Token für Authentifizierung (vom Bunker generiert)
BUNKER_API_TOKEN=

# Name des Keys im Bunker (muss dort existieren)
BUNKER_KEY_NAME=stevennoack

# Relay für Event-Publishing
RELAY_URL=wss://relay.visionfusen.org

# Base URL der Website
BASE_URL=https://wissen.codeback.de

# ===========================================
# ANALYTICS (optional)
# ===========================================

# Umami Website ID (bereits im Head.astro eingetragen)
# UMAMI_WEBSITE_ID=2948a6ed-1f76-4bfc-8849-fb34b7f478be
