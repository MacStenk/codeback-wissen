---
/**
 * Custom Footer für CodeBack Wissen
 * Backlinks zu Steven Noack, VisionFusen, CodeBack
 */
import type { Props } from '@astrojs/starlight/props';
import Default from '@astrojs/starlight/components/Footer.astro';
---

<Default {...Astro.props}><slot /></Default>

<footer class="cb-footer">
  <div class="cb-footer-content">
    <div class="cb-footer-links">
      Ein Projekt von
      <a href="https://stevennoack.de" target="_blank" rel="author">Steven Noack</a>
      <span class="cb-divider">·</span>
      <a href="https://visionfusen.org" target="_blank" rel="noopener">VisionFusen</a> Infrastruktur
      <span class="cb-divider">·</span>
      <a href="https://codeback.de" target="_blank" rel="noopener">CodeBack.de</a>
    </div>
  </div>
</footer>

<style>
  .cb-footer {
    margin-top: 2rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--sl-color-gray-5);
    font-size: 0.8rem;
  }
  
  .cb-footer-content {
    text-align: center;
  }
  
  .cb-footer-links {
    color: var(--sl-color-gray-3);
  }
  
  .cb-footer-links a {
    color: var(--sl-color-text-accent);
    text-decoration: none;
    transition: opacity 0.2s;
  }
  
  .cb-footer-links a:hover {
    opacity: 0.8;
    text-decoration: underline;
  }
  
  .cb-divider {
    color: var(--sl-color-gray-4);
    margin: 0 0.25rem;
  }
</style>
